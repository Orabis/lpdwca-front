---
interface Props {
  title: string;
  intro?: string;
  actionLabel?: string;
  actionHref?: string;
  sectionId?: string;
  sectionClass?: string;
}
const { title, intro, actionLabel, actionHref, sectionId, sectionClass } =
  Astro.props;
---

<section class:list={["section", sectionClass]} id={sectionId}>
  <header class="section__header">
    <div class="section__intro">
      <h2>{title}</h2>
      {intro && <p>{intro}</p>}
    </div>
    {
      actionLabel && actionHref && (
        <a class="section__action" href={actionHref}>
          {actionLabel}
        </a>
      )
    }
  </header>

  <div class="section__content">
    <slot />
  </div>
</section>
