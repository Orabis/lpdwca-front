---
interface Props {
  id?: string;
  title: string;
  intro?: string;
  actionLabel?: string;
  actionHref?: string;
}
const { id, title, intro, actionLabel, actionHref } = Astro.props;
---

<section class="section" id={id}>
  <header class="section__header">
    <div class="section__intro">
      <h2>{title}</h2>
      {intro && <p>{intro}</p>}
    </div>
    {
      actionLabel && actionHref && (
        <a class="section__action" href={actionHref}>
          {actionLabel}
        </a>
      )
    }
  </header>

  <div class="section__content">
    <slot />
  </div>
</section>
