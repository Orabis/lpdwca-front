---
import SectionBase from "./SectionBase.astro";
import AdvantageCard from "./AdvantageCard.astro";

interface Advantage {
  id: number;
  number: string;
  title: string;
  description: string;
}

interface Props {
  advantages: Advantage[];
  intro?: string;
  actionHref?: string;
}

const { advantages, intro, actionHref = "/licence/" } = Astro.props;
---

<SectionBase
  title="Avantages"
  intro={intro}
  actionLabel="Tout afficher"
  actionHref={actionHref}
  sectionId="avantages"
  sectionClass="section--advantages"
>
  <div class="advantages__grid">
    {
      advantages.map((item) => (
        <AdvantageCard
          number={item.number}
          title={item.title}
          description={item.description}
        />
      ))
    }
  </div>
</SectionBase>
