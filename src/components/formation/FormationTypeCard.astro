---
interface Props {
  title: string;
  description: string;
  question: string;
  iconVariant: "book" | "badge";
}

const { title, description, question, iconVariant } = Astro.props;
---

<article class="formation-type-card">
  <span class="formation-type-card__icon-box" aria-hidden="true">
    {
      iconVariant === "book" ? (
        <svg
          class="formation-type-card__icon-svg"
          viewBox="0 0 24 24"
          fill="none"
          aria-hidden="true"
        >
          <path
            d="M7.3 4.25C6.085 4.25 5.1 5.235 5.1 6.45V17.55C5.1 18.765 6.085 19.75 7.3 19.75H17.7C18.032 19.75 18.3 19.482 18.3 19.15V6.45C18.3 5.235 17.315 4.25 16.1 4.25H7.3Z"
            fill="currentColor"
          />
          <path
            d="M7.05 5.35C6.552 5.35 6.15 5.753 6.15 6.25V17.75C6.15 18.247 6.552 18.65 7.05 18.65H7.9V5.35H7.05Z"
            fill="#fffaf5"
          />
          <path
            d="M9.45 8.4C9.45 8.179 9.629 8 9.85 8H15.4C15.621 8 15.8 8.179 15.8 8.4V8.6C15.8 8.821 15.621 9 15.4 9H9.85C9.629 9 9.45 8.821 9.45 8.6V8.4Z"
            fill="#fffaf5"
          />
          <path
            d="M9.45 10.65C9.45 10.429 9.629 10.25 9.85 10.25H14.35C14.571 10.25 14.75 10.429 14.75 10.65V10.85C14.75 11.071 14.571 11.25 14.35 11.25H9.85C9.629 11.25 9.45 11.071 9.45 10.85V10.65Z"
            fill="#fffaf5"
          />
        </svg>
      ) : (
        <svg
          class="formation-type-card__icon-svg"
          viewBox="0 0 24 24"
          fill="none"
          aria-hidden="true"
        >
          <circle cx="12" cy="8.25" r="3.25" stroke="currentColor" stroke-width="1.8" />
          <path
            d="M12 4L6.1 10.55L8.4 13.1L12 9.1L15.6 13.1L17.9 10.55L12 4Z"
            fill="currentColor"
          />
          <path
            d="M8.4 13.1L5.5 9.9L3.75 11.65L7.9 16.25L10.35 14.1L8.4 13.1Z"
            fill="currentColor"
          />
          <path
            d="M15.6 13.1L18.5 9.9L20.25 11.65L16.1 16.25L13.65 14.1L15.6 13.1Z"
            fill="currentColor"
          />
          <circle cx="12" cy="16.35" r="5.15" fill="currentColor" />
          <path
            d="M12 12.75L13.08 15.02L15.55 15.33L13.72 17.05L14.19 19.48L12 18.3L9.81 19.48L10.28 17.05L8.45 15.33L10.92 15.02L12 12.75Z"
            fill="#fffaf5"
          />
        </svg>
      )
    }
  </span>
  <h2 class="formation-type-card__title">{title}</h2>
  <p class="formation-type-card__description">{description}</p>
  <p class="formation-type-card__question">{question}</p>
</article>
