---
import Logo from './Logo.astro'
import { footerNavSections, socialLinks } from '@/data/navigation'
---

<footer class='site-footer'>
  <div class='site-footer__inner'>
    <!-- Colonne marque & contact -->
    <div class='site-footer__brand'>
      <Logo class='site-footer__logo' />

      <address class='site-footer__contact'>
        <a
          href='mailto:support@lpdwca.fr'
          class='site-footer__contact-link'
        >
          <span
            class='icon icon--mail site-footer__contact-icon'
            aria-hidden='true'
          ></span>
          support@lpdwca.fr
        </a>
        <a
          href='tel:+33000000000'
          class='site-footer__contact-link'
        >
          <span
            class='icon icon--phone site-footer__contact-icon'
            aria-hidden='true'
          ></span>
          +33 00 00 00 00 00
        </a>
        <span class='site-footer__contact-item'>
          <span
            class='icon icon--location site-footer__contact-icon'
            aria-hidden='true'
          ></span>
          Quelque part en alsace
        </span>
      </address>
    </div>

    <!-- Colonnes de navigation -->
    <div class='site-footer__links'>
      {
        footerNavSections.map((section) => (
          <nav
            class='site-footer__nav'
            aria-label={section.title}
          >
            <p class='site-footer__nav-title'>{section.title}</p>
            <ul class='site-footer__nav-list'>
              {section.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class='site-footer__nav-link'
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        ))
      }

      <div class='site-footer__nav'>
        <p class='site-footer__nav-title'>Profils sociaux</p>
        <ul class='site-footer__social-list'>
          {
            socialLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class='site-footer__social-link'
                  aria-label={link.label}
                >
                  <span
                    class:list={['icon', `icon--${link.icon}`, 'site-footer__social-icon']}
                    aria-hidden='true'
                  />
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>

  <hr class='site-footer__divider' />
  <p class='site-footer__copyright'>© 2026 Lpdwca. Tous droits réservés.</p>
</footer>
