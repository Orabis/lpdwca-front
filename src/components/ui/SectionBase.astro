---
import SectionHeader from "./SectionHeader.astro";

interface Props {
  id?: string;
  title: string;
  intro?: string;
  actionLabel?: string;
  actionHref?: string;
}
const { id, title, intro, actionLabel, actionHref } = Astro.props;
---

<section class="section" id={id}>
  <SectionHeader
    title={title}
    intro={intro}
    actionLabel={actionLabel}
    actionHref={actionHref}
  />

  <div class="section__content">
    <slot />
  </div>
</section>
