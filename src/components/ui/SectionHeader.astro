---
interface Props {
  title: string
  intro?: string
  actionLabel?: string
  actionHref?: string
}
const { title, intro, actionLabel, actionHref } = Astro.props
---

<header class='section__header'>
  <div class='section__intro'>
    <h2>{title}</h2>
    {intro && <p>{intro}</p>}
  </div>
  {
    actionLabel && actionHref && (
      <a
        class='section__action'
        href={actionHref}
      >
        {actionLabel}
      </a>
    )
  }
</header>
