---
interface Props {
  title: string;
  description: string;
  imageSrc?: string;
  imageAlt?: string;
  href?: string;
  iconSrc?: string;
}

const {
  title,
  description,
  imageSrc,
  imageAlt = "",
  href = "#",
  iconSrc,
} = Astro.props;
---

<article class="course-card">
  {
    imageSrc && (
      <div class="course-card__media">
        <img
          class="course-card__img"
          src={imageSrc}
          alt={imageAlt}
          width="600"
          height="338"
        />
      </div>
    )
  }
  {
    !imageSrc && iconSrc && (
      <div class="course-card__placeholder" aria-hidden="true">
        <img
          class="course-card__placeholder-icon"
          src={iconSrc}
          width="48"
          height="48"
          alt=""
        />
      </div>
    )
  }
  <div class="course-card__body">
    <h3 class="course-card__title">{title}</h3>
    <p class="course-card__desc">{description}</p>
  </div>
  <div class="course-card__footer">
    <a class="course-card__link" href={href}>En savoir plus</a>
  </div>
</article>
