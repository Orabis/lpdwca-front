---
import { getArticles, getImageUrl } from '@/services/articles.ts'

const { limit = 3 } = Astro.props

let articles = await getArticles()
if (articles) {
  articles = articles
    .sort((a, b) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime())
    .slice(0, limit)
}

const formatDate = (dateStr: string) => {
  return new Date(dateStr).toLocaleDateString('fr-FR', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  })
}
---

{
  articles && articles.length > 0 && (
    <div class='carousel-container'>
      <div class='carousel__viewport'>
        <div class='carousel__track'>
          {articles.map((article, index) => {
            const coverUrl = article.cover ? getImageUrl(article.cover.url) : null
            return (
              <div
                class='carousel__slide'
                data-index={index}
              >
                <div class='carousel__card'>
                  <div class='carousel__image-part'>
                    {coverUrl ? (
                      <img
                        src={coverUrl}
                        alt={article.title}
                        class='carousel__img'
                      />
                    ) : (
                      <div class='carousel__img-placeholder'>
                        <span>LPDWCA</span>
                      </div>
                    )}
                    {article.category && <span class='carousel__badge'>{article.category.name}</span>}
                  </div>
                  <div class='carousel__content-part'>
                    <div class='carousel__meta'>
                      {article.author && (
                        <span class='carousel__author'>
                          <span class='carousel__author-avatar'>{article.author.name.charAt(0)}</span>
                          Par {article.author.name}
                        </span>
                      )}
                      <time
                        class='carousel__date'
                        datetime={article.publishedAt}
                      >
                        {formatDate(article.publishedAt)}
                      </time>
                    </div>

                    <h3 class='carousel__title'>{article.title}</h3>
                    <p class='carousel__description'>{article.description}</p>

                    <a
                      href={`/article/${article.slug}`}
                      class='carousel__read-more'
                    >
                      Lire l'article
                      <svg
                        xmlns='http://www.w3.org/2000/svg'
                        width='18'
                        height='18'
                        viewBox='0 0 24 24'
                        fill='none'
                        stroke='currentColor'
                        stroke-width='2.5'
                        stroke-linecap='round'
                        stroke-linejoin='round'
                      >
                        <line
                          x1='5'
                          y1='12'
                          x2='19'
                          y2='12'
                        />
                        <polyline points='12 5 19 12 12 19' />
                      </svg>
                    </a>
                  </div>
                </div>
              </div>
            )
          })}
        </div>
      </div>

      <button
        class='carousel__btn carousel__btn--prev'
        aria-label='Article précédent'
      >
        &lsaquo;
      </button>
      <button
        class='carousel__btn carousel__btn--next'
        aria-label='Article suivant'
      >
        &rsaquo;
      </button>

      <div class='carousel__dots'>
        {articles.map((_, index) => (
          <button
            class={`carousel__dot ${index === 0 ? 'active' : ''}`}
            data-dot-index={index}
            aria-label={`Aller à l'article ${index + 1}`}
          />
        ))}
      </div>
    </div>
  )
}

<style>
  .carousel-container {
    position: relative;
    width: 100%;
    max-width: 1000px;
    margin: 2rem auto;
    display: block;
  }

  .carousel__viewport {
    overflow: hidden;
    border-radius: var(--radius-md);
    box-shadow:
      0 10px 25px -5px rgba(0, 0, 0, 0.1),
      0 8px 10px -6px rgba(0, 0, 0, 0.05);
    border: 1px solid #e5e7eb;
    background-color: #ffffff;
  }

  .carousel__track {
    display: flex;
    transition: transform 0.4s ease;
    width: 100%;
  }

  .carousel__slide {
    flex: 0 0 100%;
    width: 100%;
    box-sizing: border-box;
  }

  .carousel__card {
    display: flex;
    flex-direction: row;
    height: 400px;
    width: 100%;
  }

  .carousel__image-part {
    flex: 1.2;
    position: relative;
    overflow: hidden;
    background-color: #f3f4f6;
  }

  .carousel__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .carousel__img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-hover) 100%);
    color: var(--color-text-contrast);
    font-weight: 800;
    font-size: 2rem;
    letter-spacing: 0.15em;
  }

  .carousel__badge {
    position: absolute;
    top: 1.25rem;
    left: 1.25rem;
    background-color: rgba(255, 255, 255, 0.95);
    color: var(--color-primary);
    padding: 0.35rem 0.85rem;
    font-size: 0.75rem;
    font-weight: 700;
    border-radius: 9999px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .carousel__content-part {
    flex: 1;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background-color: #ffffff;
    box-sizing: border-box;
  }

  .carousel__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.825rem;
    color: #6b7280;
    margin-bottom: 1.25rem;
  }

  .carousel__author {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    color: #374151;
  }

  .carousel__author-avatar {
    width: 22px;
    height: 22px;
    background-color: rgba(14, 40, 134, 0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-primary);
    text-transform: uppercase;
  }

  .carousel__date {
    font-weight: 500;
  }

  .carousel__title {
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--color-text-heading);
    margin: 0 0 1rem 0;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .carousel__description {
    font-size: 0.95rem;
    color: #4b5563;
    line-height: 1.6;
    margin: 0 0 2rem 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .carousel__read-more {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-primary);
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
  }

  .carousel__read-more:hover {
    color: var(--color-primary-hover);
    text-decoration: none;
  }

  .carousel__btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: var(--color-text-heading);
    font-size: 4rem;
    font-weight: 300;
    cursor: pointer;
    z-index: 10;
    line-height: 1;
    padding: 0;
    opacity: 0.6;
  }

  .carousel__btn:hover {
    color: var(--color-primary);
    opacity: 1;
  }

  .carousel__btn--prev {
    left: -32px;
  }

  .carousel__btn--next {
    right: -32px;
  }

  .carousel__dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1.25rem;
  }

  .carousel__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: #d1d5db;
    border: none;
    padding: 0;
    cursor: pointer;
  }

  .carousel__dot.active {
    background-color: var(--color-primary);
  }

  @media (max-width: 768px) {
    .carousel__card {
      flex-direction: column;
      height: auto;
    }

    .carousel__image-part {
      height: 220px;
    }

    .carousel__content-part {
      padding: 1.5rem;
    }

    .carousel__title {
      font-size: 1.4rem;
    }

    .carousel__btn {
      font-size: 3rem;
    }

    .carousel__btn--prev {
      left: 10px;
    }

    .carousel__btn--next {
      right: 10px;
    }
  }
</style>

<script>
  const carousels = document.querySelectorAll('.carousel-container')

  carousels.forEach((carousel) => {
    const track = carousel.querySelector('.carousel__track') as HTMLElement
    const prevBtn = carousel.querySelector('.carousel__btn--prev')
    const nextBtn = carousel.querySelector('.carousel__btn--next')
    const dots = carousel.querySelectorAll('.carousel__dot')
    const slides = carousel.querySelectorAll('.carousel__slide')
    const totalSlides = slides.length

    if (totalSlides === 0) return

    let currentIndex = 0
    let autoplayInterval: number

    function updateCarousel() {
      if (!track) return
      track.style.transform = `translateX(-${currentIndex * 100}%)`

      dots.forEach((dot, index) => {
        if (index === currentIndex) {
          dot.classList.add('active')
        } else {
          dot.classList.remove('active')
        }
      })
    }

    function startAutoplay() {
      if (totalSlides <= 1) return
      autoplayInterval = window.setInterval(() => {
        currentIndex = (currentIndex + 1) % totalSlides
        updateCarousel()
      }, 6000)
    }

    function stopAutoplay() {
      if (autoplayInterval) {
        clearInterval(autoplayInterval)
      }
    }

    function resetAutoplay() {
      stopAutoplay()
      startAutoplay()
    }

    if (prevBtn) {
      prevBtn.addEventListener('click', () => {
        currentIndex = (currentIndex - 1 + totalSlides) % totalSlides
        updateCarousel()
        resetAutoplay()
      })
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', () => {
        currentIndex = (currentIndex + 1) % totalSlides
        updateCarousel()
        resetAutoplay()
      })
    }

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const index = parseInt(dot.getAttribute('data-dot-index') || '0', 10)
        currentIndex = index
        updateCarousel()
        resetAutoplay()
      })
    })

    startAutoplay()
  })
</script>
