---
interface Props {
  title: string;
  href: string;
  text: string;
  icon: string;
}
const { title, href, text,  icon } = Astro.props;
---

<section class="site-header__banner">
  <div class="banner">
    <p class="banner__text">{title}</p>
    <a class="banner__link" href={href} aria-label="Plus d'infos">{text}
      <span class="banner__icon"></span>
    </a>
  </div>
</section>
