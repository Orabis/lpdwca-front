---
import Button from "@/components/ui/Button.astro";

interface Props {
  number: string;
  title: string;
  description: string;
}

const { number, title, description } = Astro.props;
---

<article class="adv-card">
  <div class="adv-card__number">{number}</div>
  <h3 class="adv-card__title">{title}</h3>
  <p class="adv-card__text">{description}</p>
  <Button variant="outline" aria-label={title}>
    <span class="icon icon--arrow-right" aria-hidden="true"></span>
  </Button>
</article>
