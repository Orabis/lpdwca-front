---
/*
  CourseCard — carte de présentation d'un cours (page d'accueil)
  Props :
    - title       : intitulé du cours
    - description : description courte
    - imageSrc    : URL de l'image (optionnel)
    - imageAlt    : texte alternatif de l'image (optionnel)
    - href        : lien "En savoir plus" (optionnel, défaut "#")
  TODO : alimenter via Strapi (collection Courses)
*/
import Button from "@/components/ui/Button.astro";

interface Props {
  title: string;
  description: string;
  imageSrc?: string;
  imageAlt?: string;
  href?: string;
}

const { title, description, imageSrc, imageAlt = "", href = "#" } = Astro.props;
---

<article class="course-card">
  {
    imageSrc && (
      <img
        class="course-card__img"
        src={imageSrc}
        alt={imageAlt}
        width="600"
        height="338"
        loading="lazy"
      />
    )
  }
  <div class="course-card__body">
    <h3 class="course-card__title">{title}</h3>
    <p class="course-card__desc">{description}</p>
  </div>
  <div class="course-card__footer">
    <Button href={href} variant="outline">En savoir plus</Button>
  </div>
</article>
