---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Button from "@/components/Button.astro";
import mailIcon from "@/assets/svg/mail-icon.svg";
import phoneIcon from "@/assets/svg/phone-icon.svg";
import locationIcon from "@/assets/svg/location-icon.svg";
import facebookIcon from "@/assets/svg/facebook.svg";
import linkedinIcon from "@/assets/svg/linkedin-icon.svg";
import twitterIcon from "@/assets/svg/x-twitter.svg";

const infoCards = [
  {
    icon: mailIcon,
    label: "support@lpdwca.fr",
    href: "mailto:support@lpdwca.fr",
  },
  {
    icon: phoneIcon,
    label: "+33 00 00 00 00 00",
  },
  {
    icon: locationIcon,
    label: "Quelque part en alsace",
  },
];
---

<BaseLayout title="Contact — LPDWCA" pageClass="page--contact">
  <section class="page-header page-header--split" aria-labelledby="contact-title">
    <div class="page-header__inner page-header__inner--split">
      <h1 class="page-header__title" id="contact-title">Contactez-nous</h1>
      <p class="page-header__description">
        Bienvenue sur la page contact de LPDWCA, où vous pouvez faire une
        demande de renseignement. Que vous soyez un particulier souhaitant
        améliorer ses compétences ou une entreprise à la recherche de solutions
        de développement professionnel, nous avons à cœur de répondre à vos
        questionnement.
      </p>
    </div>
  </section>

  <section class="contact-section" aria-labelledby="contact-form-title">
    <div class="contact-panel">
      <div class="contact-panel__form">
        <h2 class="sr-only" id="contact-form-title">Formulaire de contact</h2>

        <form class="contact-form">
          <div class="contact-form__grid">
            <div class="contact-field">
              <label class="contact-field__label" for="contact-firstname">
                Prénom
              </label>
              <input
                class="contact-field__input"
                id="contact-firstname"
                name="firstname"
                type="text"
                placeholder="Entrez votre prénom"
              />
            </div>

            <div class="contact-field">
              <label class="contact-field__label" for="contact-lastname">
                Nom de famille
              </label>
              <input
                class="contact-field__input"
                id="contact-lastname"
                name="lastname"
                type="text"
                placeholder="Entrez votre nom de famille"
              />
            </div>

            <div class="contact-field">
              <label class="contact-field__label" for="contact-email">
                E-mail
              </label>
              <input
                class="contact-field__input"
                id="contact-email"
                name="email"
                type="email"
                placeholder="Entrez votre adresse e-mail"
              />
            </div>

            <div class="contact-field">
              <label class="contact-field__label" for="contact-phone">
                Téléphone
              </label>
              <input
                class="contact-field__input"
                id="contact-phone"
                name="phone"
                type="tel"
                placeholder="Entrez votre numéro de téléphone"
              />
            </div>

            <div class="contact-field contact-field--full">
              <label class="contact-field__label" for="contact-subject">
                Objet
              </label>
              <input
                class="contact-field__input"
                id="contact-subject"
                name="subject"
                type="text"
                placeholder="Indiquez votre sujet"
              />
            </div>

            <div class="contact-field contact-field--full">
              <label class="contact-field__label" for="contact-message">
                Message
              </label>
              <textarea
                class="contact-field__input contact-field__input--textarea"
                id="contact-message"
                name="message"
                placeholder="Écrivez votre message ici..."
              ></textarea>
            </div>
          </div>

          <div class="contact-form__actions">
            <Button type="submit">Envoyez votre message</Button>
          </div>
        </form>
      </div>

      <aside class="contact-panel__aside" aria-label="Informations de contact">
        {
          infoCards.map((item) => (
            <article class="contact-info-card">
              <span class="contact-info-card__icon-box" aria-hidden="true">
                <img
                  class="contact-info-card__icon"
                  src={item.icon.src}
                  width="24"
                  height="24"
                  alt=""
                />
              </span>
              {item.href ? (
                <a class="contact-info-card__text" href={item.href}>
                  {item.label}
                </a>
              ) : (
                <p class="contact-info-card__text">{item.label}</p>
              )}
            </article>
          ))
        }

        <article class="contact-info-card">
          <div class="contact-info-card__social" aria-label="Profils sociaux">
            <a class="contact-info-card__social-link" href="#" aria-label="Facebook">
              <img src={facebookIcon.src} width="24" height="24" alt="" />
            </a>
            <a class="contact-info-card__social-link" href="#" aria-label="X Twitter">
              <img src={twitterIcon.src} width="24" height="24" alt="" />
            </a>
            <a class="contact-info-card__social-link" href="#" aria-label="LinkedIn">
              <img src={linkedinIcon.src} width="24" height="24" alt="" />
            </a>
          </div>
          <p class="contact-info-card__text">Profils sur les réseaux sociaux</p>
        </article>
      </aside>
    </div>
  </section>
</BaseLayout>
