---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { getArticles, getImageUrl, type Article } from '@/services/articles.ts'
import { marked } from 'marked'

export async function getStaticPaths() {
  const articles = await getArticles()
  return (
    articles?.map((article) => {
      return {
        params: { article: article.slug },
        props: { data: article },
      }
    }) || []
  )
}

const { data } = Astro.props as { data: Article }

const formatDate = (dateStr: string) => {
  return new Date(dateStr).toLocaleDateString('fr-FR', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  })
}

const parsedBlocks = data.blocks
  ? await Promise.all(
      data.blocks.map(async (block) => {
        if (block.__component === 'shared.rich-text' && block.body) {
          return {
            ...block,
            htmlContent: await marked.parse(block.body),
          }
        }
        return block
      })
    )
  : []

const coverUrl = data.cover ? getImageUrl(data.cover.url) : null
---

<BaseLayout title={`LPDWCA | ${data.title}`}>
  <div class='article-page'>
    <div class='article-container'>
      <a
        href='/articles'
        class='back-link'
      >
        <svg
          xmlns='http://www.w3.org/2000/svg'
          width='20'
          height='20'
          viewBox='0 0 24 24'
          fill='none'
          stroke='currentColor'
          stroke-width='2.5'
          stroke-linecap='round'
          stroke-linejoin='round'
        >
          <line
            x1='19'
            y1='12'
            x2='5'
            y2='12'
          ></line>
          <polyline points='12 19 5 12 12 5'></polyline>
        </svg>
        Retour aux articles
      </a>

      <article class='article-main'>
        <header class='article-header'>
          {data.category && <span class='article-category'>{data.category.name}</span>}
          <h1 class='article-title'>{data.title}</h1>
          <p class='article-description'>{data.description}</p>

          <div class='article-meta'>
            {
              data.author && (
                <div class='article-author'>
                  <span class='article-author__avatar'>{data.author.name.charAt(0)}</span>
                  <div class='article-author__info'>
                    <span class='article-author__name'>{data.author.name}</span>
                    <span class='article-author__email'>{data.author.email}</span>
                  </div>
                </div>
              )
            }
            <div class='article-date-info'>
              <span class='article-meta__label'>Publié le</span>
              <time
                class='article-date'
                datetime={data.publishedAt}
              >
                {formatDate(data.publishedAt)}
              </time>
            </div>
          </div>
        </header>

        {
          coverUrl && (
            <div class='article-cover-container'>
              <img
                src={coverUrl}
                alt={data.title}
                class='article-cover-image'
              />
            </div>
          )
        }

        <div class='article-content'>
          {
            parsedBlocks.length > 0 ? (
              parsedBlocks.map((block: any) => {
                switch (block.__component) {
                  case 'shared.rich-text':
                    return (
                      <div
                        class='block-rich-text'
                        set:html={block.htmlContent}
                      />
                    )

                  case 'shared.quote':
                    return (
                      <blockquote class='block-quote'>
                        <svg
                          class='quote-icon'
                          xmlns='http://www.w3.org/2000/svg'
                          width='48'
                          height='48'
                          viewBox='0 0 24 24'
                          fill='currentColor'
                        >
                          <path d='M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z' />
                        </svg>
                        <p class='quote-body'>{block.body}</p>
                        {block.title && <cite class='quote-author'>— {block.title}</cite>}
                      </blockquote>
                    )

                  case 'shared.media':
                    if (block.file) {
                      const blockMediaUrl = getImageUrl(block.file.url)
                      return (
                        <figure class='block-media'>
                          <img
                            src={blockMediaUrl}
                            alt={block.file.alternativeText || ''}
                          />
                          {block.file.caption && <figcaption>{block.file.caption}</figcaption>}
                        </figure>
                      )
                    }
                    return null

                  case 'shared.slider':
                    if (block.files && block.files.length > 0) {
                      return (
                        <div class='block-gallery'>
                          {block.files.map((file: any) => (
                            <div class='gallery-item'>
                              <img
                                src={getImageUrl(file.url)}
                                alt={file.alternativeText || ''}
                              />
                            </div>
                          ))}
                        </div>
                      )
                    }
                    return null

                  default:
                    return null
                }
              })
            ) : (
              <div class='block-rich-text'>
                <p>{data.description}</p>
              </div>
            )
          }
        </div>
      </article>
    </div>
  </div>
</BaseLayout>

<style>
  .article-page {
    padding: 3rem 1.5rem;
    min-height: 100%;
  }

  .article-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #4b5563;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    margin-bottom: 2.5rem;
    transition:
      color 0.2s ease,
      transform 0.2s ease;
  }

  .back-link:hover {
    color: var(--color-primary);
    transform: translateX(-4px);
    text-decoration: none;
  }

  .article-main {
    background: #ffffff;
    border-radius: var(--radius-md);
    border: 1px solid #e5e7eb;
    overflow: hidden;
    padding: 2.5rem;
  }

  @media (max-width: 640px) {
    .article-main {
      padding: 1.5rem;
    }
  }

  .article-header {
    margin-bottom: 2rem;
  }

  .article-category {
    display: inline-block;
    background-color: rgba(14, 40, 134, 0.1);
    color: var(--color-primary);
    padding: 0.25rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 700;
    border-radius: 24px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1.25rem;
  }

  .article-title {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--color-text-heading);
    margin: 0 0 1rem 0;
    line-height: 1.2;
  }

  @media (max-width: 640px) {
    .article-title {
      font-size: 1.85rem;
    }
  }

  .article-description {
    font-size: 1.15rem;
    color: #4b5563;
    line-height: 1.6;
    margin: 0 0 2rem 0;
    border-left: 4px solid var(--color-primary);
    padding-left: 1.25rem;
    font-style: italic;
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid #f3f4f6;
  }

  .article-author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .article-author__avatar {
    width: 40px;
    height: 40px;
    background-color: var(--color-primary);
    color: var(--color-text-contrast);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.15rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .article-author__info {
    display: flex;
    flex-direction: column;
  }

  .article-author__name {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text-heading);
  }

  .article-author__email {
    font-size: 0.8rem;
    color: #6b7280;
  }

  .article-date-info {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  @media (max-width: 640px) {
    .article-date-info {
      align-items: flex-start;
    }
  }

  .article-meta__label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #9ca3af;
    margin-bottom: 0.25rem;
  }

  .article-date {
    font-size: 0.95rem;
    font-weight: 600;
    color: #374151;
  }

  .article-cover-container {
    margin: 2rem 0;
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
    background-color: #f3f4f6;
  }

  .article-cover-image {
    width: 100%;
    height: auto;
    max-height: 450px;
    object-fit: cover;
    display: block;
  }

  .article-content {
    color: #1f2937;
    line-height: 1.8;
    font-size: 1rem;
  }

  .article-content :global(p) {
    margin-bottom: 1.5rem;
  }

  .article-content :global(h2) {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text-heading);
    margin: 2.5rem 0 1rem 0;
    line-height: 1.3;
  }

  .article-content :global(h3) {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-text-heading);
    margin: 2rem 0 1rem 0;
    line-height: 1.3;
  }

  .article-content :global(ul) {
    list-style-type: disc;
    margin-left: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .article-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .article-content :global(strong) {
    color: #000000;
    font-weight: 700;
  }

  .article-content :global(code) {
    background-color: #f3f4f6;
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    font-size: 0.9rem;
    font-family: monospace;
    color: #ef4444;
  }

  .article-content :global(blockquote) {
    border-left: 4px solid var(--color-primary);
    padding: 1rem 1.5rem;
    margin: 2rem 0;
    background-color: #f3f4f6;
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-style: italic;
    color: #4b5563;
  }

  .block-quote {
    position: relative;
    border-left: 4px solid var(--color-primary);
    background: #f9f9fb;
    padding: 2rem;
    margin: 2.5rem 0;
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }

  .quote-icon {
    position: absolute;
    top: 1rem;
    right: 1.5rem;
    color: rgba(14, 40, 134, 0.08);
    pointer-events: none;
  }

  .quote-body {
    font-size: 1.25rem;
    font-style: italic;
    color: #374151;
    line-height: 1.6;
    margin: 0 0 1rem 0;
    position: relative;
    z-index: 1;
  }

  .quote-author {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-primary);
    display: block;
    text-align: right;
  }

  .block-media {
    margin: 2rem 0;
    text-align: center;
  }

  .block-media img {
    max-width: 100%;
    border-radius: var(--radius-md);
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
    height: auto;
  }

  .block-media figcaption {
    font-size: 0.85rem;
    color: #6b7280;
    margin-top: 0.75rem;
    font-style: italic;
  }

  .block-gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
    margin: 2rem 0;
  }

  .gallery-item {
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
    background-color: #f3f4f6;
  }

  .gallery-item img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .gallery-item img:hover {
    transform: scale(1.03);
  }
</style>
