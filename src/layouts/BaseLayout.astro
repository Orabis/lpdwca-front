---
import "@/styles/global.css";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  pageClass?: string;
}

const {
  title,
  description = "Licence professionnelle développement web, communication et apprentissages à distance. Formation universitaire complète pour booster votre carrière dans le digital.",
  pageClass = "",
} = Astro.props;
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="author"
      content="BOYER Laurent, HALIFA Anysse, MERKEL Leo, MERITO Hassan"
    />
    <link rel="icon" type="image/svg+xml" href="/assets/Logo.svg" />
    <link rel="icon" type="image/png" href="/assets/faviconLPDWCA.png" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class:list={["page", pageClass]}>
    <Header
      title="Licence professionnelle développement web communication et apprentissages. "
      text="Plus d'infos"
      href="/licence"
    />
    <main>
      <slot />
    </main>
    <Footer />
    <script>
      import { initNavToggle } from "../scripts/nav-toggle";
      initNavToggle();
    </script>
  </body>
</html>
